---
interface Props {
    title: string;
    content: string;
}

const { title, content } = Astro.props;
---

<div class="container bg-[var(--color-bg-card)] justify-center items-center border-2 border-[var(--color-border)] flex flex-col rounded-lg py-10 w-[25%]">
    <div class="w-[80%]">
        <h3 class="text-2xl text-center mb-3">{title}</h3>
        <p class="text-[1rem] text-center">{content}</p>
    </div>
</div>